---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import home from '../content/home.json';

const metricIcons = ['fa-chart-line', 'fa-circle-check', 'fa-chart-column'];
const benefitIcons = ['fa-regular fa-clock', 'fa-solid fa-chart-line', 'fa-solid fa-shield-halved', 'fa-solid fa-sterling-sign'];
const serviceIcons = ['fa-gears', 'fa-code', 'fa-wand-magic-sparkles'];
const whyItems = home.why.items.map((item) => {
  const [lead, ...rest] = item.split(' — ');
  return { lead, detail: rest.join(' — ') };
});
const clientLogos = [
  { src: '/assets/jci-logo.png', alt: 'JCI' },
  { src: '/assets/lloyds-bank-logo.png', alt: 'Lloyds Bank' },
  { src: '/assets/morrisons-logo.png', alt: 'Morrisons' },
  { src: '/assets/santander-logo.png', alt: 'Santander' },
  { src: '/assets/vw-logo.png', alt: 'Volkswagen' },
  { src: '/assets/sky-logo.png', alt: 'Sky' },
];
---

<BaseLayout title={home.seo.title} description={home.seo.description}>
  <SiteHeader />

  <main>
    <section class="hero section" id="home">
      <div class="container hero-grid">
        <div class="hero-content">
          <p class="eyebrow">{home.hero.eyebrow}</p>
          <h1>
            {home.hero.lineOne}<br />{home.hero.lineTwo}<br />{home.hero.lineThree}{' '}
            <span>{home.hero.highlight}</span>
          </h1>
          <p class="hero-copy">{home.hero.copy}</p>
          <div class="button-group">
            <a class="btn btn-primary" href="#contact">{home.ctaLabel}</a>
          </div>
          <div class="trusted">
            <span>{home.hero.trustedLabel}</span>
            <div class="client-logos" aria-label="Client experience">
              {clientLogos.map((logo) => <img src={logo.src} alt={logo.alt} />)}
            </div>
          </div>
        </div>
        <div class="hero-visual">
          {home.metrics.map((metric, index) => (
            <article class={`metric-card metric-${['one', 'two', 'three'][index]}`}>
              <span class="metric-icon"><i class={`fa-solid ${metricIcons[index]}`} aria-hidden="true"></i></span>
              <div><small>{metric.label}</small><strong>{metric.value}</strong></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="benefits section" aria-labelledby="benefits-title">
      <div class="container">
        <div class="section-intro">
          <p class="eyebrow">{home.benefits.eyebrow}</p>
          <h2 class="section-heading" id="benefits-title">{home.benefits.title}</h2>
          <p>{home.benefits.copy}</p>
        </div>
        <div class="benefit-grid">
          {home.benefits.items.map((benefit, index) => (
            <article class="benefit-item">
              <span class="icon-circle"><i class={benefitIcons[index]} aria-hidden="true"></i></span>
              <div><h3>{benefit.title}</h3><p>{benefit.copy}</p></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="services section" id="services" aria-labelledby="services-title">
      <div class="container">
        <div class="dark-heading">
          <p class="eyebrow">{home.services.eyebrow}</p>
          <h2 class="section-heading" id="services-title">{home.services.title}</h2>
        </div>
        <div class="service-grid">
          {home.services.items.map((service, index) => (
            <article class="service-item">
              <span class="icon-circle"><i class={`fa-solid ${serviceIcons[index]}`} aria-hidden="true"></i></span>
              <h3>{service.title}</h3>
              <p>{service.copy}</p>
              <ul class="check-list">{service.features.map((feature) => <li>{feature}</li>)}</ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="why section" id="about" aria-labelledby="why-title">
      <div class="container why-grid">
        <div class="why-content">
          <p class="eyebrow">{home.why.eyebrow}</p>
          <h2 class="section-heading" id="why-title">{home.why.title}</h2>
          <ul class="why-list">
            {whyItems.map((item, index) => (
              <li>
                <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                {index === 0
                  ? <span><strong>{item.lead}</strong>{item.detail && ` — ${item.detail}`}</span>
                  : <span>{item.lead}{item.detail && ` — ${item.detail}`}</span>}
              </li>
            ))}
          </ul>
        </div>
        <div class="image-placeholder dashboard-image" role="img" aria-label="Software analytics dashboard image"></div>
      </div>
    </section>

    <section class="cta-section section" id="contact" aria-labelledby="cta-title">
      <div class="container">
        <div class="cta-panel">
          <p class="eyebrow">{home.contact.eyebrow}</p>
          <h2 class="section-heading" id="cta-title">{home.contact.title}</h2>
          <p>{home.contact.copy}</p>
          <a class="btn btn-primary" href={home.contact.url}>{home.ctaLabel}</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
