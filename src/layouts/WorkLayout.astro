---
import BaseLayout from './BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title: string;
  description: string;
  client: string;
}

const { title, description, client } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen bg-[#fbfaf7] text-[#111b17]">
    <SiteHeader />

    <main class="py-8 pb-9 max-[760px]:pt-[1.4rem]">
      <div class="mx-auto w-[min(calc(100%-3rem),1420px)] max-md:w-[min(calc(100%-2rem),1420px)]">
        <nav class="my-[0.1rem] mb-[1.7rem] flex items-center gap-3 overflow-hidden text-base whitespace-nowrap text-[#151e1a] max-[760px]:text-[0.86rem]" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <i class="fa-solid fa-chevron-right text-[0.62rem] text-[#69716d]" aria-hidden="true"></i>
          <a href="/work/">Work</a>
          <i class="fa-solid fa-chevron-right text-[0.62rem] text-[#69716d]" aria-hidden="true"></i>
          <span class="text-[#87845d] max-[760px]:overflow-hidden max-[760px]:text-ellipsis" aria-current="page">{client}</span>
        </nav>
        <slot />
      </div>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
