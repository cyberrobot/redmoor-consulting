---
import home from '../content/home.json';
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="brand brand-light" href="/" aria-label="Redmoor Consulting home">
          <img class="brand-logo" src="/assets/logo-dark.png" alt="Redmoor Consulting" />
        </a>
        <p>{home.footer.copy}</p>
      </div>
      <div>
        <h2>Services</h2>
        <ul>{home.services.items.map((service) => <li>{service.title}</li>)}</ul>
      </div>
      <div>
        <h2>Connect</h2>
        <ul class="contact-list">
          <li>
            <a href={`mailto:${home.footer.email}`}>
              <i class="fa-regular fa-envelope" aria-hidden="true"></i>
              <span>{home.footer.email}</span>
            </a>
          </li>
          <li>
            <a href={home.footer.linkedInUrl} aria-label="Redmoor Consulting on LinkedIn">
              <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
              <span>{home.footer.linkedInLabel}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>{home.footer.copyright}</p>
      <button class="cookie-settings-link" type="button">Cookie settings</button>
    </div>
  </div>
</footer>
